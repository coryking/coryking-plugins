{
  "name": "project-mining",
  "version": "2.0.0",
  "description": "Mine project histories for behavioral evidence. Search chat logs, git history, docs, and code for concrete examples of specific patterns, values, or skills.",
  "author": {
    "name": "Cory King",
    "email": "me@coryk.ing",
    "url": "https://github.com/coryking"
  },
  "homepage": "https://github.com/coryking/coryking-plugins",
  "repository": "https://github.com/coryking/coryking-plugins",
  "license": "MIT",
  "keywords": ["chat-history", "evidence-mining", "project-mining", "cc-explorer", "mcp"],
  "agents": "./agents/",
  "skills": "./skills/",
  "mcpServers": {
    "cc-explorer": {
      "command": "uv",
      "args": ["run", "--project", "${CLAUDE_PLUGIN_ROOT}", "cc-explorer"]
    }
  }
}
